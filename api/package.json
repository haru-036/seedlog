{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "generate": "drizzle-kit generate",
    "migration:local": "wrangler d1 migrations apply seedlog --local",
    "migration:remote": "wrangler d1 migrations apply seedlog --remote",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "oxfmt . && oxlint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.2",
    "@seedlog/schema": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.6",
    "hono-openapi": "^1.3.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  }
}
