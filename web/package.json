{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "oxfmt . && oxlint .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@seedlog/schema": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  }
}
