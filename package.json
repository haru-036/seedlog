{
  "name": "seedlog",
  "private": true,
  "workspaces": [
    "web",
    "api",
    "schema",
    "slides"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
